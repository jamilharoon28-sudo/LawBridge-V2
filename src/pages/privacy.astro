---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy | LawBridge">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Privacy Policy</p>
      <h1>How LawBridge collects and uses information.</h1>
      <p>
        This policy explains how LawBridge handles information submitted through
        forms, events, resources and enquiries.
      </p>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="table">
        <div class="row">
          <strong>Who we are</strong>
          <div>
            <p>
              LawBridge is a legal education and professional development
              platform supporting aspiring lawyers.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Information collected</strong>
          <div>
            <p>
              We may collect names, email addresses, educational information,
              professional information and enquiry details submitted through
              forms.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>How information is used</strong>
          <div>
            <p>
              Information is used to respond to enquiries, manage participation,
              share relevant updates and improve LawBridge services.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Marketing communications</strong>
          <div>
            <p>
              Users may receive relevant LawBridge communications where consent
              has been provided. Users can unsubscribe at any time.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Data security</strong>
          <div>
            <p>
              Reasonable measures are taken to protect submitted information and
              restrict unauthorised access.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Your rights</strong>
          <div>
            <p>
              Individuals may request access, correction or deletion of their
              information where applicable.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Contact</strong>
          <div>
            <p>
              Privacy-related enquiries can be submitted through the LawBridge
              contact page.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
