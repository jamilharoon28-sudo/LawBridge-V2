---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const page = await getCollection("pages");
const webinars = await getCollection("webinars");

const data = page.find((p) => p.slug === "webinars")?.data ?? {};
const hero = data.hero ?? {};
---

<BaseLayout title="Webinars | LawBridge">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{hero.eyebrow ?? "Webinars"}</p>
        <h1>{hero.heading ?? "LawBridge Webinars"}</h1>
        <p>{hero.description ?? "Join practical webinars with legal professionals, mentors and industry speakers."}</p>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="grid g3">
        {webinars.map((webinar) => (
          <article class="card">
            <h3>{webinar.data.title}</h3>
            <p>{webinar.data.description}</p>
            <p><small>{webinar.data.date}</small></p>
            <p>Status: {webinar.data.status}</p>
            <p>Location: {webinar.data.location}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
