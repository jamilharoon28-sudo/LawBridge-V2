---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

const page = await getEntry("pages", "webinars");
const webinars = await getCollection("webinars");

const { Content } = await page.render();
---

<BaseLayout title={`${page.data.title} | LawBridge`}>
  <main>
    <h1>{page.data.title}</h1>

    <Content />

    {webinars.map((webinar) => (
      <article>
        <h2>{webinar.data.title}</h2>
        <p>{webinar.data.date.toLocaleDateString()}</p>
        <a href={`/webinars/${webinar.slug}`}>View webinar</a>
      </article>
    ))}
  </main>
</BaseLayout>
