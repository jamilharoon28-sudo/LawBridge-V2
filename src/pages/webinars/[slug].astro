---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const webinars = await getCollection("webinars");

  return webinars.map((webinar) => ({
    params: { slug: webinar.slug },
    props: { webinar }
  }));
}

const { webinar } = Astro.props;
const { Content } = await webinar.render();
---

<BaseLayout title={`${webinar.data.title} | LawBridge`}>
  <main>
    <article>
      <h1>{webinar.data.title}</h1>
      <p>{webinar.data.date.toLocaleDateString()}</p>
      <Content />
    </article>
  </main>
</BaseLayout>
