---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const page = await getCollection("pages");
const blogPosts = await getCollection("blog");

const data = page.find((p) => p.slug === "blog")?.data ?? {};
const hero = data.hero ?? {};
---

<BaseLayout title="Blog | LawBridge">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{hero.eyebrow ?? "Blog"}</p>
        <h1>{hero.heading ?? "LawBridge Updates & Insights"}</h1>
        <p>{hero.description ?? "Read the latest updates, articles, and practical insights from LawBridge."}</p>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="grid g3">
        {blogPosts.map((post) => (
          <article class="card">
            <h3>{post.data.title}</h3>
            {post.data.description && <p>{post.data.description}</p>}
            <p><small>{post.data.date}</small></p>
            <a class="btn secondary" href={`/blog/${post.slug}`}>Read More</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
