---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | LawBridge">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>Page not found.</h1>
      <p>
        The page you are looking for may have moved or is not currently available.
      </p>

      <div class="actions">
        <a class="btn primary" href="/">Return Home</a>
        <a class="btn ghost" href="/resources">Explore Resources</a>
      </div>
    </div>
  </section>
</BaseLayout>
