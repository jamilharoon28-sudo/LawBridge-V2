---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

// Pull homepage content
const page = await getEntry("pages", "homepage");
const data = page?.data ?? {};
const hero = data?.hero ?? {};
const sections = data?.sections ?? {};
const dashboard = data?.dashboard ?? {};
const buttons = data?.buttons ?? {};
---

<BaseLayout title="LawBridge | Practical Legal Development">
  <header class="hero">
    <div class="container hero-grid">
      <div>
        {hero.eyebrow && <p class="eyebrow">{hero.eyebrow}</p>}
        {hero.heading && <h1>{hero.heading}</h1>}
        {hero.description && <p>{hero.description}</p>}

        <div class="cta-buttons">
          {buttons?.primaryButtonText && buttons?.primaryButtonLink && (
            <a href={buttons.primaryButtonLink} class="btn primary">{buttons.primaryButtonText}</a>
          )}
          {buttons?.secondaryButtonText && buttons?.secondaryButtonLink && (
            <a href={buttons.secondaryButtonLink} class="btn secondary">{buttons.secondaryButtonText}</a>
          )}
          {buttons?.tertiaryButtonText && buttons?.tertiaryButtonLink && (
            <a href={buttons.tertiaryButtonLink} class="btn tertiary">{buttons.tertiaryButtonText}</a>
          )}
        </div>
      </div>

      {dashboard.heading && (
        <div class="dashboard-card">
          {dashboard.label && <span class="pill">{dashboard.label}</span>}
          {dashboard.heading && <h2>{dashboard.heading}</h2>}
          {dashboard.description && <p>{dashboard.description}</p>}

          {dashboard.items && dashboard.items.length > 0 && (
            <ul>
              {dashboard.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </div>
      )}
    </div>
  </header>

  <!-- Sections -->
  {sections?.problem?.heading && (
    <section class="section problem">
      {sections.problem.eyebrow && <p class="eyebrow">{sections.problem.eyebrow}</p>}
      {sections.problem.heading && <h2>{sections.problem.heading}</h2>}
      {sections.problem.description && <p>{sections.problem.description}</p>}
    </section>
  )}

  {sections?.method?.heading && (
    <section class="section method">
      {sections.method.eyebrow && <p class="eyebrow">{sections.method.eyebrow}</p>}
      {sections.method.heading && <h2>{sections.method.heading}</h2>}
      {sections.method.description && <p>{sections.method.description}</p>}
    </section>
  )}
</BaseLayout>
