---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const settings = await getEntry("settings", "general");

if (!settings) {
  throw new Error("General settings not found.");
}

const siteName = settings.data.siteName;
const tagline = settings.data.tagline;
---

<BaseLayout title={siteName}>
  <main>
    <h1>{siteName}</h1>
    <p>{tagline}</p>
  </main>
</BaseLayout>
