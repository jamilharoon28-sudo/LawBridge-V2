---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const pages = await getCollection("pages");
const homePage = pages.find((page) => page.slug === "home");

const title = homePage?.data.title ?? "LawBridge | Practical Legal Development";
const eyebrow =
  homePage?.data.eyebrow ?? "Practical legal development for the SQE, QWE and AI era";
const heading =
  homePage?.data.heading ?? "Bridge the gap between legal education and real-world legal practice.";
const description =
  homePage?.data.description ??
  "LawBridge helps aspiring lawyers build practical legal capability through structured learning, real-world exercises, mentor guidance, workshops, webinars and commercial awareness training.";
---

<BaseLayout title={title}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{heading}</h1>
        <p>{description}</p>

        <div class="actions">
          <a class="btn primary" href="/contact?tab=student">Join as a Student</a>
          <a class="btn ghost" href="/contact?tab=mentor">Become a Mentor</a>
          <a class="btn ghost" href="/resources">Explore the Curriculum</a>
        </div>

        <div class="hero-links">
          <a href="/resources">Explore Resources</a>
          <a href="/blog">Read the Blog</a>
        </div>
      </div>

      <div class="dashboard">
        <div class="dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="dash-top">
          <div>
            <span class="pill">LawBridge Skills Pathway</span>
            <strong>Build practical legal capability</strong>
          </div>
          <span class="pill">Launch</span>
        </div>

        <div class="skill-list">
          <div class="skill-row">
            <div class="skill-top">
              <strong>Legal analysis</strong>
              <small>86%</small>
            </div>
            <div class="bar"><span style="width:86%"></span></div>
          </div>

          <div class="skill-row">
            <div class="skill-top">
              <strong>Commercial awareness</strong>
              <small>78%</small>
            </div>
            <div class="bar"><span style="width:78%"></span></div>
          </div>

          <div class="skill-row">
            <div class="skill-top">
              <strong>Professional confidence</strong>
              <small>92%</small>
            </div>
            <div class="bar"><span style="width:92%"></span></div>
          </div>
        </div>

        <div class="dash-bottom">
          <p>
            Legal knowledge matters. Confidence, judgement, drafting ability,
            client awareness and commercial thinking are built through practice.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
