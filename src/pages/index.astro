---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const pages = await getCollection("pages");
const homePage = pages.find((page) => page.slug === "home");

const data = homePage?.data ?? {};

const title = data.title ?? "LawBridge | Practical Legal Development";
const eyebrow =
  data.eyebrow ?? "Practical legal development for the SQE, QWE and AI era";
const heading =
  data.heading ?? "Bridge the gap between legal education and real-world legal practice.";
const description =
  data.description ??
  "LawBridge helps aspiring lawyers build practical legal capability through structured learning, real-world exercises, mentor guidance, workshops, webinars and commercial awareness training.";
---

<BaseLayout title={title}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{heading}</h1>
        <p>{description}</p>

        <div class="actions">
          <a class="btn primary" href="/contact?tab=student">Join as a Student</a>
          <a class="btn ghost" href="/contact?tab=mentor">Become a Mentor</a>
          <a class="btn ghost" href="/resources">Explore the Curriculum</a>
        </div>

        <div class="hero-links">
          <a href="/resources">Explore Resources</a>
          <a href="/blog">Read the Blog</a>
        </div>
      </div>

      <div class="dashboard">
        <div class="dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="dash-top">
          <div>
            <span class="pill">LawBridge Skills Pathway</span>
            <strong>Build practical legal capability</strong>
          </div>
          <span class="pill">Launch</span>
        </div>

        <div class="skill-list">
          <div class="skill-row">
            <div class="skill-top">
              <strong>Legal analysis</strong>
              <small>86%</small>
            </div>
            <div class="bar"><span style="width:86%"></span></div>
          </div>

          <div class="skill-row">
            <div class="skill-top">
              <strong>Commercial awareness</strong>
              <small>78%</small>
            </div>
            <div class="bar"><span style="width:78%"></span></div>
          </div>

          <div class="skill-row">
            <div class="skill-top">
              <strong>Professional confidence</strong>
              <small>92%</small>
            </div>
            <div class="bar"><span style="width:92%"></span></div>
          </div>
        </div>

        <div class="dash-bottom">
          <p>
            Legal knowledge matters. Confidence, judgement, drafting ability,
            client awareness and commercial thinking are built through practice.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section data-section="problem" class="section cream">
    <span class="section-marker">01</span>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The problem</p>
        <h2>Legal education is changing. The skills gap is growing.</h2>
        <p>
          Aspiring lawyers are entering a profession shaped by the SQE, QWE
          flexibility, commercial pressure and rapid advances in AI. Many students
          still need practical exposure to how legal work is delivered.
        </p>
      </div>

      <div class="grid g3">
        <article class="card">
          <span>01</span>
          <h3>Practice exposure</h3>
          <p>
            Understand how lawyers analyse problems, communicate risk and work
            with clients.
          </p>
        </article>

        <article class="card">
          <span>02</span>
          <h3>Commercial context</h3>
          <p>
            Connect legal work to business priorities, market pressure and client
            objectives.
          </p>
        </article>

        <article class="card">
          <span>03</span>
          <h3>Responsible technology</h3>
          <p>
            Learn how AI can support legal learning without replacing judgement.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section data-section="method" class="section navy overlap">
    <span class="section-marker">02</span>
    <div class="container">
      <div class="section-head light-text">
        <p class="eyebrow">The LawBridge method</p>
        <h2>A practical development model built around real capability.</h2>
        <p>
          LawBridge is a practical legal skills ecosystem designed to help aspiring
          lawyers learn, practise, reflect and grow.
        </p>
      </div>

      <div class="method">
        <div class="chip">1. Learn</div>
        <div class="chip">2. Practise</div>
        <div class="chip">3. Reflect</div>
        <div class="chip">4. Connect</div>
        <div class="chip">5. Progress</div>
      </div>
    </div>
  </section>

  <section data-section="curriculum" class="section light">
    <span class="section-marker">03</span>
    <div class="container split">
      <div>
        <p class="eyebrow">Practical skills curriculum</p>
        <h2>Develop the skills legal education alone cannot fully provide.</h2>
        <p>
          The LawBridge curriculum is built around practical skills aspiring
          lawyers need to become more commercially aware, confident and
          practice-ready.
        </p>
        <a class="btn primary" href="/resources">View the Curriculum</a>
      </div>

      <div class="grid g2">
        <article class="curric">
          <span class="icon">01</span>
          <h3>Legal analysis</h3>
          <p>Break down legal problems and apply structured legal reasoning.</p>
        </article>

        <article class="curric">
          <span class="icon">02</span>
          <h3>Drafting</h3>
          <p>Develop clear, accurate and practical written legal communication.</p>
        </article>

        <article class="curric">
          <span class="icon">03</span>
          <h3>Commercial awareness</h3>
          <p>Understand clients, sectors, business pressure and market context.</p>
        </article>

        <article class="curric">
          <span class="icon">04</span>
          <h3>Professional confidence</h3>
          <p>Build confidence through practice, feedback and mentor guidance.</p>
        </article>
      </div>
    </div>
  </section>

  <section data-section="pathways" class="section cream overlap">
    <span class="section-marker">04</span>
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Choose your pathway</p>
        <h2>Start where you are. Build towards where you want to go.</h2>
        <p>
          Each pathway routes users into the right journey while keeping the
          experience simple and conversion-focused.
        </p>
      </div>

      <div class="grid g4">
        <article class="card">
          <span>S</span>
          <h3>For Students</h3>
          <p>
            Build practical legal confidence through mentorship, resources,
            webinars and structured skills development.
          </p>
          <a href="/contact?tab=student">Start as a student</a>
        </article>

        <article class="card">
          <span>G</span>
          <h3>For Graduates & SQE Candidates</h3>
          <p>
            Strengthen career readiness, commercial awareness and ability to
            discuss real legal work.
          </p>
          <a href="/students">Explore support</a>
        </article>

        <article class="card">
          <span>M</span>
          <h3>For Mentors</h3>
          <p>
            Share expertise through mentorship, webinars, workshops, content or
            practical feedback.
          </p>
          <a href="/contact?tab=mentor">Become a mentor</a>
        </article>

        <article class="card">
          <span>P</span>
          <h3>For Partners</h3>
          <p>
            Collaborate to support students, societies, universities, firms and
            legal teams.
          </p>
          <a href="/contact?tab=partner">Partner with us</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section navy">
    <div class="container cta-panel">
      <div>
        <p class="eyebrow">Start your LawBridge journey</p>
        <h2>Ready to build practical legal confidence?</h2>
        <p>
          Join LawBridge and start developing the skills, judgement and commercial
          awareness needed for modern legal practice.
        </p>
      </div>

      <div class="actions">
        <a class="btn primary" href="/contact?tab=student">Join as a Student</a>
        <a class="btn ghost" href="/contact?tab=mentor">Become a Mentor</a>
      </div>
    </div>
  </section>
</BaseLayout>
