---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const pages = await getCollection("pages");
const mentorsPage = pages.find((page) => page.slug === "mentors");

const title = mentorsPage?.data.title ?? "Mentors | LawBridge";
const eyebrow = mentorsPage?.data.eyebrow ?? "Mentors";
const heading =
  mentorsPage?.data.heading ??
  "Help aspiring lawyers understand the realities of legal practice.";
const description =
  mentorsPage?.data.description ??
  "LawBridge invites legal professionals to share practical insight, career guidance, commercial perspective and skills-based support.";
---

<BaseLayout title={title}>
  <section class="page-hero">
    <div class="container page-grid">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{heading}</h1>
        <p>{description}</p>

        <div class="actions">
          <a class="btn primary" href="/contact?tab=mentor">Become a Mentor</a>
          <a class="btn ghost" href="/webinars">View Webinars</a>
        </div>
      </div>

      <div class="dashboard mini">
        <div class="dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="mini-card">
          <strong>Share insight</strong>
          <span>Help students understand real legal work.</span>
        </div>

        <div class="mini-card">
          <strong>Support confidence</strong>
          <span>Guide aspiring lawyers with practical perspective.</span>
        </div>

        <div class="mini-card">
          <strong>Contribute flexibly</strong>
          <span>Mentor, speak, write or support workshops.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container split">
      <div>
        <p class="eyebrow">Why mentors matter</p>
        <h2>Practical insight can change how students see the profession.</h2>
        <p>
          Mentors help students understand client expectations, commercial
          context, professional judgement and career realities.
        </p>
      </div>

      <div class="tags">
        <span>Associates</span>
        <span>Partners</span>
        <span>General Counsel</span>
        <span>CLOs</span>
        <span>In-house counsel</span>
        <span>Legal ops</span>
        <span>Legal tech</span>
        <span>Consultants</span>
      </div>
    </div>
  </section>

  <section class="section light overlap">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Ways to contribute</p>
        <h2>Flexible contribution, meaningful impact.</h2>
        <p>
          LawBridge should make contribution realistic for busy professionals.
        </p>
      </div>

      <div class="grid g3">
        <article class="card">
          <span>01</span>
          <h3>One-to-one mentorship</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>

        <article class="card">
          <span>02</span>
          <h3>Group mentorship</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>

        <article class="card">
          <span>03</span>
          <h3>Webinars</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>

        <article class="card">
          <span>04</span>
          <h3>Workshops</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>

        <article class="card">
          <span>05</span>
          <h3>Content contribution</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>

        <article class="card">
          <span>06</span>
          <h3>Short videos</h3>
          <p>
            Support students with practical insight, feedback and professional
            perspective.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section navy">
    <div class="container cta-panel">
      <div>
        <p class="eyebrow">Become a LawBridge mentor</p>
        <h2>Share your experience with the next generation of lawyers.</h2>
        <p>
          Help students understand how legal work happens in practice.
        </p>
      </div>

      <div class="actions">
        <a class="btn primary" href="/contact?tab=mentor">Become a Mentor</a>
        <a class="btn ghost" href="/contact?tab=partner">Partner with LawBridge</a>
      </div>
    </div>
  </section>
</BaseLayout>
