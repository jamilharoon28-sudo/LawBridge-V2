---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

const page = await getEntry("pages", "mentors");

if (!page) {
  throw new Error("Mentors page content not found.");
}

const mentors = await getCollection("mentors");
const { Content } = await page.render();
---

<BaseLayout title={`${page.data.title} | LawBridge`}>
  <main>
    <h1>{page.data.title}</h1>

    <Content />

    {mentors.map((mentor) => (
      <article>
        <h2>{mentor.data.name}</h2>
        <p>{mentor.data.role}</p>
        {mentor.data.organisation && <p>{mentor.data.organisation}</p>}
      </article>
    ))}
  </main>
</BaseLayout>
