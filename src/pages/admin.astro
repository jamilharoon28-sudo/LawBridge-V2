---
import BaseLayout from "../layouts/BaseLayout.astro";

const adminCards = [
  {
    title: "Homepage",
    fields: "hero, sections, buttons, dashboard",
    editPath: "/cms/#/collections/pages/entries/home",
    previewPath: "/",
  },
  {
    title: "Resources",
    fields: "filters, cards, downloads",
    editPath: "/cms/#/collections/pages/entries/resources",
    previewPath: "/resources",
  },
  {
    title: "Blog Posts",
    fields: "articles, dates, authors",
    editPath: "/cms/#/collections/blog",
    previewPath: "/blog",
  },
  {
    title: "Webinars",
    fields: "title, date, status",
    editPath: "/cms/#/collections/webinars",
    previewPath: "/webinars",
  },
  {
    title: "Workshops",
    fields: "title, date, status",
    editPath: "/cms/#/collections/workshops",
    previewPath: "/workshops",
  },
  {
    title: "Mentors",
    fields: "page text, sections, cards",
    editPath: "/cms/#/collections/pages/entries/mentors",
    previewPath: "/mentors",
  },
];

const workflowSteps = [
  "Choose a page or collection",
  "Edit text, dates, cards or links",
  "Save/publish in CMS",
  "Netlify rebuilds the site",
  "Website content updates",
];
---

<BaseLayout title="LawBridge Admin Dashboard">
  <section class="admin-hero">
    <div class="container">
      <p class="admin-pill">https://cheery-peony-49a0f2.netlify.app/admin</p>

      <div class="admin-intro">
        <div>
          <p class="eyebrow">Private LawBridge Area</p>
          <h1>LawBridge Admin Dashboard</h1>
          <p>
            Your admin page stays simple and branded. The Edit buttons open the
            real CMS editing screens, so you can update the website without
            touching code.
          </p>
        </div>

        <div class="admin-auth-panel">
          <span id="admin-status">Checking admin access...</span>
          <button id="admin-logout" type="button">Log out</button>
        </div>
      </div>

      <div class="admin-layout">
        <section class="admin-panel">
          <div class="admin-panel-header">
            <h2>LawBridge Admin Panel</h2>
          </div>

          <div class="admin-panel-body">
            <p>
              Manage editable pages and collections from one simple dashboard.
            </p>

            <div class="admin-grid">
              {adminCards.map((card) => (
                <article class="admin-card">
                  <h3>{card.title}</h3>
                  <p>Editable fields: {card.fields}</p>

                  <div class="admin-actions">
                    <a href={card.editPath} class="admin-button primary">
                      Edit {card.title}
                    </a>
                    <a href={card.previewPath} class="admin-button secondary" target="_blank">
                      Preview
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <aside class="cms-panel">
          <div class="cms-panel-header">
            <h2>Real CMS Editor</h2>
          </div>

          <div class="cms-panel-body">
            <p class="cms-route">/cms</p>

            <ol>
              {workflowSteps.map((step, index) => (
                <li>
                  <span>{index + 1}</span>
                  <p>{step}</p>
                </li>
              ))}
            </ol>

            <a href="/cms/" class="admin-button primary full">
              Open CMS
            </a>
          </div>
        </aside>
      </div>

      <div class="admin-result">
        <strong>Result:</strong> /admin stays simple and branded. /cms becomes
        the real editing engine. No normal website pages are redesigned.
      </div>
    </div>
  </section>

  <style is:inline>
    .admin-hero {
      min-height: 100vh;
      padding: 4rem 0;
      background:
        radial-gradient(circle at top right, rgba(231, 182, 95, 0.14), transparent 34%),
        linear-gradient(180deg, #f8f1e4 0%, #fbf7ef 100%);
      color: #061b31;
    }

    .admin-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin: 1.5rem 0 2rem;
      padding: 0.9rem 1.35rem;
      border-radius: 999px;
      background: #061b31;
      color: #ffffff;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      box-shadow: 0 16px 38px rgba(6, 27, 49, 0.18);
    }

    .admin-intro {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: end;
      margin-bottom: 2.4rem;
    }

    .admin-intro h1 {
      max-width: 900px;
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.6rem, 6vw, 5.5rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: #061b31;
    }

    .admin-intro p:not(.eyebrow) {
      max-width: 820px;
      margin-top: 1rem;
      font-size: 1.1rem;
      line-height: 1.7;
      color: #26384c;
    }

    .admin-auth-panel {
      min-width: 260px;
      padding: 1rem 1.15rem;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(201, 150, 82, 0.28);
      box-shadow: 0 18px 50px rgba(6, 27, 49, 0.1);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      color: #26384c;
      font-weight: 700;
    }

    .admin-auth-panel button {
      width: fit-content;
      border: 1px solid rgba(201, 150, 82, 0.34);
      background: #ffffff;
      color: #061b31;
      padding: 0.65rem 1rem;
      border-radius: 999px;
      font-weight: 800;
      cursor: pointer;
    }

    .admin-layout {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(340px, 1fr);
      gap: 2rem;
      align-items: start;
    }

    .admin-panel,
    .cms-panel {
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid rgba(201, 150, 82, 0.32);
      background: rgba(255, 255, 255, 0.7);
      box-shadow: 0 28px 80px rgba(6, 27, 49, 0.12);
    }

    .admin-panel-header,
    .cms-panel-header {
      padding: 1.35rem 1.6rem;
      background: #061b31;
      color: #ffffff;
    }

    .admin-panel-header h2,
    .cms-panel-header h2 {
      margin: 0;
      font-size: clamp(1.4rem, 2vw, 2rem);
      letter-spacing: 0.03em;
      color: #ffffff;
    }

    .admin-panel-body,
    .cms-panel-body {
      padding: 1.6rem;
    }

    .admin-panel-body > p {
      margin: 0 0 1.5rem;
      color: #26384c;
      font-size: 1.05rem;
    }

    .admin-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .admin-card {
      padding: 1.25rem;
      border-radius: 20px;
      border: 1px solid rgba(201, 150, 82, 0.28);
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 14px 42px rgba(6, 27, 49, 0.08);
    }

    .admin-card h3 {
      margin: 0 0 0.3rem;
      font-size: 1.6rem;
      letter-spacing: 0.03em;
      color: #061b31;
    }

    .admin-card p {
      margin: 0;
      color: #415169;
      font-size: 0.95rem;
    }

    .admin-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .admin-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.65rem 1rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 900;
      letter-spacing: 0.01em;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .admin-button:hover {
      transform: translateY(-2px);
    }

    .admin-button.primary {
      background: linear-gradient(135deg, #e7b65f, #d39b45);
      color: #061b31;
      box-shadow: 0 12px 28px rgba(211, 155, 69, 0.22);
    }

    .admin-button.secondary {
      border: 1px solid rgba(201, 150, 82, 0.32);
      background: #ffffff;
      color: #061b31;
    }

    .admin-button.full {
      width: 100%;
      margin-top: 1.25rem;
    }

    .cms-route {
      margin: 0 0 1rem;
      font-size: 1.55rem;
      font-weight: 900;
      color: #061b31;
    }

    .cms-panel ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1rem;
    }

    .cms-panel li {
      display: grid;
      grid-template-columns: 38px 1fr;
      gap: 0.8rem;
      align-items: center;
    }

    .cms-panel li span {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: #e7b65f;
      color: #061b31;
      font-weight: 900;
      font-size: 0.9rem;
    }

    .cms-panel li p {
      margin: 0;
      color: #26384c;
      font-size: 1rem;
      line-height: 1.45;
    }

    .admin-result {
      margin-top: 2rem;
      padding: 1rem 1.25rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(201, 150, 82, 0.28);
      color: #061b31;
      font-size: 1.05rem;
      box-shadow: 0 18px 48px rgba(6, 27, 49, 0.08);
    }

    @media (max-width: 1050px) {
      .admin-intro,
      .admin-layout {
        grid-template-columns: 1fr;
      }

      .admin-auth-panel {
        min-width: 0;
      }
    }

    @media (max-width: 720px) {
      .admin-hero {
        padding: 2rem 0;
      }

      .admin-grid {
        grid-template-columns: 1fr;
      }

      .admin-pill {
        max-width: 100%;
        overflow-wrap: anywhere;
      }
    }
  </style>

  <script is:inline>
    const adminStatus = document.getElementById("admin-status");
    const logoutButton = document.getElementById("admin-logout");

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", (user) => {
        if (!user) {
          window.location.href = "/login/";
          return;
        }

        const roles = user.app_metadata?.roles || [];

        if (!roles.includes("admin")) {
          if (adminStatus) {
            adminStatus.textContent =
              "You are signed in, but this account does not have the admin role.";
          }
          return;
        }

        if (adminStatus) {
          adminStatus.textContent = `Signed in as ${user.email}`;
        }
      });

      if (logoutButton) {
        logoutButton.addEventListener("click", () => {
          window.netlifyIdentity.logout();
          window.location.href = "/login/";
        });
      }
    } else if (adminStatus) {
      adminStatus.textContent = "Netlify Identity is not loaded.";
    }
  </script>
</BaseLayout>
