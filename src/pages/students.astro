---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const pages = await getCollection("pages");
const studentsPage = pages.find((page) => page.slug === "students");

const title = studentsPage?.data.title ?? "Students | LawBridge";
const eyebrow = studentsPage?.data.eyebrow ?? "Students";
const heading =
  studentsPage?.data.heading ??
  "Build the practical legal confidence your studies alone may not provide.";
const description =
  studentsPage?.data.description ??
  "LawBridge helps aspiring lawyers gain practical exposure, commercial awareness, mentor guidance and structured skills development.";
---

<BaseLayout title={title}>
  <section class="page-hero">
    <div class="container page-grid">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{heading}</h1>
        <p>{description}</p>

        <div class="actions">
          <a class="btn primary" href="/contact?tab=student">Join as a Student</a>
          <a class="btn ghost" href="/resources">View Curriculum</a>
        </div>
      </div>

      <div class="dashboard mini">
        <div class="dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="mini-card">
          <strong>Learn</strong>
          <span>Structured resources and explanations.</span>
        </div>

        <div class="mini-card">
          <strong>Practise</strong>
          <span>Exercises, skills labs and scenarios.</span>
        </div>

        <div class="mini-card">
          <strong>Grow</strong>
          <span>Mentor guidance and portfolio evidence.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container split">
      <div>
        <p class="eyebrow">Who this is for</p>
        <h2>Designed for different stages of the legal journey.</h2>
        <p>
          LawBridge supports students, graduates, SQE candidates, career switchers
          and early-stage future lawyers who want to move beyond theory.
        </p>
      </div>

      <div class="tags">
        <span>Law students</span>
        <span>Recent graduates</span>
        <span>SQE candidates</span>
        <span>Career switchers</span>
        <span>A-Level students</span>
        <span>Junior lawyers</span>
      </div>
    </div>
  </section>

  <section class="section light overlap">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What you will gain</p>
        <h2>Move from understanding the law to applying it.</h2>
        <p>
          The student journey should feel clear, practical and useful from the
          first interaction.
        </p>
      </div>

      <div class="grid g4">
        <article class="card">
          <span>01</span>
          <h3>Practical legal skills</h3>
          <p>Drafting, research, analysis, negotiation and communication.</p>
        </article>

        <article class="card">
          <span>02</span>
          <h3>Commercial awareness</h3>
          <p>Understand client priorities and business context.</p>
        </article>

        <article class="card">
          <span>03</span>
          <h3>Professional exposure</h3>
          <p>Learn from mentors, webinars and practical perspectives.</p>
        </article>

        <article class="card">
          <span>04</span>
          <h3>Portfolio evidence</h3>
          <p>Prepare to evidence learning through exercises and reflection.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section navy">
    <div class="container">
      <div class="section-head light-text">
        <p class="eyebrow">Your LawBridge journey</p>
        <h2>A development path from discovery to confidence.</h2>
        <p>
          This journey can later become the structure for dashboards and learning
          paths.
        </p>
      </div>

      <div class="pathways">
        <div class="path-card">
          <span class="num">01</span>
          <div>
            <h3>Discover</h3>
            <p>Learn what practical legal capability looks like.</p>
          </div>
        </div>

        <div class="path-card">
          <span class="num">02</span>
          <div>
            <h3>Learn</h3>
            <p>Access resources, webinars and structured explanations.</p>
          </div>
        </div>

        <div class="path-card">
          <span class="num">03</span>
          <div>
            <h3>Practise</h3>
            <p>Complete exercises and attend workshops.</p>
          </div>
        </div>

        <div class="path-card">
          <span class="num">04</span>
          <div>
            <h3>Receive Feedback</h3>
            <p>Learn from mentors and professionals.</p>
          </div>
        </div>

        <div class="path-card">
          <span class="num">05</span>
          <div>
            <h3>Develop Confidence</h3>
            <p>Build commercial awareness and judgement.</p>
          </div>
        </div>

        <div class="path-card">
          <span class="num">06</span>
          <div>
            <h3>Progress</h3>
            <p>Use your experience to support applications and interviews.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Start your LawBridge journey</p>
        <h2>Start building practical legal confidence.</h2>
        <p>
          Join LawBridge and begin developing the skills, judgement and awareness
          needed for modern legal practice.
        </p>

        <div class="actions" style="justify-content:center">
          <a class="btn primary" href="/contact?tab=student">Join as a Student</a>
          <a class="btn secondary" href="/resources">View Curriculum</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
