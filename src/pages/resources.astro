---
import BaseLayout from "../layouts/BaseLayout.astro";

const resources = [
  {
    title: "Contract Breakdown Guide",
    category: "Contract breakdowns",
    type: "Guide",
    description:
      "Understand how commercial contracts are structured and how key clauses manage risk.",
  },
  {
    title: "Commercial Awareness Starter Pack",
    category: "Commercial awareness",
    type: "Toolkit",
    description:
      "Build confidence reading business news, market updates and client-focused issues.",
  },
  {
    title: "Legal Career Roadmap",
    category: "Career readiness",
    type: "Roadmap",
    description:
      "Understand routes into law and the skills needed to prepare for each stage.",
  },
  {
    title: "SQE-to-Practice Explainer",
    category: "SQE to practice",
    type: "Explainer",
    description:
      "Connect SQE knowledge with practical legal scenarios and professional expectations.",
  },
  {
    title: "Responsible AI Learning Guide",
    category: "Responsible AI",
    type: "Guide",
    description:
      "Use AI carefully as a learning support tool while preserving legal judgement.",
  },
  {
    title: "Interview Preparation Checklist",
    category: "Application guidance",
    type: "Checklist",
    description:
      "Prepare structured examples for applications, interviews and assessment centres.",
  },
];

const categories = [
  "Contract breakdown guides",
  "Commercial templates",
  "Application guides",
  "Interview prep",
  "Commercial awareness",
  "Career roadmaps",
  "Practice areas",
  "Case studies",
  "SQE-to-practice",
  "Responsible AI",
];
---

<BaseLayout title="Resources | LawBridge">
  <section class="page-hero">
    <div class="container page-grid">
      <div>
        <p class="eyebrow">Resources</p>
        <h1>Practical legal resources for aspiring lawyers.</h1>
        <p>
          Access guides, toolkits, templates, explainers and practical materials
          designed to build commercial awareness and career readiness.
        </p>

        <div class="actions">
          <a class="btn primary" href="#resources-list">Explore Resources</a>
          <a class="btn ghost" href="/contact?tab=resource">Download Resource</a>
        </div>
      </div>

      <div class="dashboard mini">
        <div class="dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="mini-card">
          <strong>Guides</strong>
          <span>Clear practical explanations.</span>
        </div>

        <div class="mini-card">
          <strong>Templates</strong>
          <span>Useful tools for structured learning.</span>
        </div>

        <div class="mini-card">
          <strong>Career support</strong>
          <span>Resources for applications and confidence.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section cream" id="resources-list">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Featured resources</p>
        <h2>Start with practical tools you can use.</h2>
        <p>
          Useful downloadable resources can generate leads and build trust.
        </p>
      </div>

      <div class="grid g3">
        {resources.map((resource) => (
          <article class="resource">
            <span class="pill">{resource.type}</span>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>

            <div class="meta">
              <span>{resource.category}</span>
            </div>

            <a class="link" href="/contact?tab=resource">Download</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section light overlap">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Resource categories</p>
        <h2>A practical library that can grow over time.</h2>
        <p>
          These categories prepare the site for a future structured learning
          platform.
        </p>
      </div>

      <div class="tags">
        {categories.map((category) => (
          <span>{category}</span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
