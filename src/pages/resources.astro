---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const page = await getCollection("pages");
const resources = await getCollection("resources");

const data = page.find((p) => p.slug === "resources")?.data ?? {};
const hero = data.hero ?? {};
const filters = data.filters ?? {};
---

<BaseLayout title="Resources | LawBridge">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{hero.eyebrow ?? "Resources"}</p>
        <h1>{hero.heading ?? "Practical legal skills resources."}</h1>
        <p class="hero-lead">{hero.description ?? "Download student packs and tutor guides for LawBridge practical legal skills simulations."}</p>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="resource-controls">
        <input id="resourceSearch" class="resource-search" type="search" placeholder="Search by skill, scenario, code or difficulty..." aria-label="Search resources" />

        <button class="resource-filter active" data-filter-type="all">All</button>
        <button class="resource-filter" data-filter-type="student">Student Packs</button>
        <button class="resource-filter" data-filter-type="tutor">Tutor Guides</button>

        <select id="skillFilter" aria-label="Filter resources by skill">
          <option value="all">All skills</option>
          {filters.skills?.map((skill) => <option value={skill}>{skill}</option>)}
        </select>
      </div>

      <p class="resource-results-count" aria-live="polite">
        Showing <strong id="visibleResourceCount">{resources.length}</strong> of <strong>{resources.length}</strong> simulations
      </p>

      <div class="resource-library">
        {resources.map((res) => (
          <article class="resource-card is-showing" data-skill={res.data.skill} data-search={`${res.data.code} ${res.data.skill} ${res.data.scenario} ${res.data.difficulty} ${res.data.description}`.toLowerCase()}>
            <div>
              <span class="resource-code">{res.data.code}</span>
              <p class="eyebrow">{res.data.skill}</p>
              <h3>{res.data.scenario}</h3>
              <p class="difficulty-badge">{res.data.difficulty}</p>
              <p class="resource-summary">{res.data.description}</p>
            </div>

            <div class="resource-downloads">
              {res.data.student && <a class="btn primary resource-download student-download" href={res.data.student} download>Download Student Pack</a>}
              {res.data.tutor && <a class="btn secondary resource-download tutor-download" href={res.data.tutor} download>Download Tutor Guide</a>}
            </div>
          </article>
        ))}
      </div>

      <div class="resource-empty-state" hidden>
        <h3>No matching resources found</h3>
        <p>Try searching a different keyword or selecting another skill.</p>
      </div>
    </div>
  </section>

  <script is:inline>
    const filterButtons = document.querySelectorAll(".resource-filter[data-filter-type]");
    const skillFilter = document.querySelector("#skillFilter");
    const searchInput = document.querySelector("#resourceSearch");
    const cards = document.querySelectorAll(".resource-card");
    const visibleCount = document.querySelector("#visibleResourceCount");
    const emptyState = document.querySelector(".resource-empty-state");

    let currentType = "all";

    function applyFilters() {
      const currentSkill = skillFilter?.value || "all";
      const searchTerm = searchInput?.value.trim().toLowerCase() || "";
      let shownCount = 0;

      cards.forEach((card, index) => {
        const matchesSkill = currentSkill === "all" || card.dataset.skill === currentSkill;
        const matchesSearch = !searchTerm || card.dataset.search.includes(searchTerm);

        const studentButton = card.querySelector(".student-download");
        const tutorButton = card.querySelector(".tutor-download");

        if (studentButton) studentButton.style.display = currentType === "tutor" ? "none" : "inline-flex";
        if (tutorButton) tutorButton.style.display = currentType === "student" ? "none" : "inline-flex";

        const shouldShow = matchesSkill && matchesSearch;

        if (shouldShow) {
          shownCount += 1;
          card.style.display = "flex";
          requestAnimationFrame(() => {
            card.classList.remove("is-hiding");
            card.classList.add("is-showing");
          });
        } else {
          card.classList.remove("is-showing");
          card.classList.add("is-hiding");
          setTimeout(() => { card.style.display = "none"; }, 350);
        }
      });

      if (visibleCount) visibleCount.textContent = shownCount.toString();
      if (emptyState) emptyState.hidden = shownCount !== 0;
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        filterButtons.forEach((b) => b.classList.remove("active"));
        button.classList.add("active");
        currentType = button.dataset.filterType;
        applyFilters();
      });
    });

    skillFilter?.addEventListener("change", applyFilters);
    searchInput?.addEventListener("input", applyFilters);

    applyFilters();
  </script>
</BaseLayout>
