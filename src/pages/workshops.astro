---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const page = await getCollection("pages");
const workshops = await getCollection("workshops");

const data = page.find((p) => p.slug === "workshops")?.data ?? {};
const hero = data.hero ?? {};
---

<BaseLayout title="Workshops | LawBridge">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{hero.eyebrow ?? "Workshops"}</p>
        <h1>{hero.heading ?? "LawBridge Workshops"}</h1>
        <p>{hero.description ?? "Explore our practical legal skills workshops for students and graduates."}</p>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="grid g3">
        {workshops.map((ws) => (
          <article class="card">
            <h3>{ws.data.title}</h3>
            <p>{ws.data.description}</p>
            <p><small>{ws.data.date}</small></p>
            <p>Status: {ws.data.status}</p>
            <p>Location: {ws.data.location}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
