---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Use | LawBridge">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Terms of Use</p>
      <h1>Terms governing use of the LawBridge platform.</h1>
      <p>
        By accessing LawBridge, users agree to these terms and conditions.
      </p>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="table">
        <div class="row">
          <strong>Purpose</strong>
          <div>
            <p>
              LawBridge provides educational, career-development and professional
              learning opportunities for aspiring lawyers.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>No legal advice</strong>
          <div>
            <p>
              Content, mentoring, webinars, workshops and resources are provided
              for educational purposes only and do not constitute legal advice.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>User conduct</strong>
          <div>
            <p>
              Users are expected to engage respectfully and professionally when
              participating in LawBridge activities.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Intellectual property</strong>
          <div>
            <p>
              LawBridge content remains the property of LawBridge unless stated
              otherwise.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>External links</strong>
          <div>
            <p>
              LawBridge may link to external websites and resources. LawBridge
              is not responsible for external content.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Changes</strong>
          <div>
            <p>
              LawBridge may update these terms periodically to reflect platform
              developments.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Contact</strong>
          <div>
            <p>
              Questions regarding these terms can be submitted through the
              LawBridge contact page.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
