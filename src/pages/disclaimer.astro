---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Disclaimer | LawBridge">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Disclaimer</p>
      <h1>LawBridge is an educational and career-development platform.</h1>
      <p>
        LawBridge content, mentoring, webinars, workshops and resources are for
        educational and professional development purposes only.
      </p>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="table">
        <div class="row">
          <strong>No legal advice</strong>
          <div>
            <p>
              LawBridge does not provide legal advice. Nothing on this website,
              in resources, during mentoring or through events should be relied
              upon as legal advice.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>No solicitor-client relationship</strong>
          <div>
            <p>
              Use of LawBridge does not create a solicitor-client relationship,
              lawyer-client relationship or professional retainer.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Educational purpose</strong>
          <div>
            <p>
              Materials are designed to support learning, career confidence,
              practical awareness and professional development.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Mentoring boundaries</strong>
          <div>
            <p>
              Mentoring is intended for career guidance, educational support and
              professional insight. Mentors should not provide advice on live
              legal matters.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>External contributors</strong>
          <div>
            <p>
              Views shared by mentors, speakers or contributors are their own
              and do not necessarily represent LawBridge.
            </p>
          </div>
        </div>

        <div class="row">
          <strong>Professional advice</strong>
          <div>
            <p>
              Users should seek appropriate professional advice for any specific
              legal, regulatory or career decision where required.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
