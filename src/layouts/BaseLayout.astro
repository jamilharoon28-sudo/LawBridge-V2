---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "LawBridge",
  description = "LawBridge is a legal education and development platform for aspiring lawyers, students, graduates and legal professionals."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
</head>

<body>
  <Header />

  <slot />

  <Footer />
</body>
</html>
